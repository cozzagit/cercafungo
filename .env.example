# CercaFungo — Environment Variables

# API per il modello ML (opzionale, per classificazione cloud)
ML_API_URL=https://api.example.com/v1/classify
ML_API_KEY=your_api_key_here

# Mapbox (per mappe premium — opzionale, usa react-native-maps default)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Sentry (error tracking — opzionale)
SENTRY_DSN=https://your_sentry_dsn_here
